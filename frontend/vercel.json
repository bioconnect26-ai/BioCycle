{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, immutable, max-age=31536000"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/.*",
      "headers": {
        "cache-control": "public, max-age=3600, s-maxage=3600"
      },
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "@vite-api-base-url"
  }
}
